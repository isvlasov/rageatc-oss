{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bash-safety-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/rules/\"*.md"
          },
          {
            "type": "command",
            "command": "type \"%CLAUDE_PLUGIN_ROOT%\\rules\\*.md\""
          },
          {
            "type": "command",
            "command": "echo rageatc-code-oss failsafe: if the rageatc-code-oss operating rules are not visible in this hook output, invoke the rageatc-code-oss:loading-rules skill to load them before proceeding."
          }
        ]
      }
    ]
  }
}
